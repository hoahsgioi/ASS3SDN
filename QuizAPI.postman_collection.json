{
  "info": {
    "name": "Quiz API - ASS3",
    "_postman_id": "quiz-api-ass3-collection",
    "description": "Collection for Quiz REST API with user authentication, admin and author privileges.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "userToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "questionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "quizId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Ordinary User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john\",\n  \"password\": \"123456\",\n  \"admin\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/register",
              "host": ["{{baseUrl}}"],
              "path": ["users", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('userToken', res.token);",
                  "    console.log('userToken saved:', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Register Admin User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"adminUser\",\n  \"password\": \"admin123\",\n  \"admin\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/register",
              "host": ["{{baseUrl}}"],
              "path": ["users", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('adminToken', res.token);",
                  "    console.log('adminToken saved:', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login Ordinary User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/login",
              "host": ["{{baseUrl}}"],
              "path": ["users", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('userToken', res.token);",
                  "    console.log('userToken saved:', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login Admin User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"adminUser\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/login",
              "host": ["{{baseUrl}}"],
              "path": ["users", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('adminToken', res.token);",
                  "    console.log('adminToken saved:', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET All Users (Admin only) ✅",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
          }
        },
        {
          "name": "GET All Users (Ordinary User) ❌ 403",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
          }
        },
        {
          "name": "GET All Users (No Token) ❌ 401",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
          }
        }
      ]
    },
    {
      "name": "Questions",
      "item": [
        {
          "name": "GET All Questions (Anyone) ✅",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/questions",
              "host": ["{{baseUrl}}"],
              "path": ["questions"]
            }
          }
        },
        {
          "name": "GET Single Question (Anyone) ✅",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/questions/{{questionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["questions", "{{questionId}}"]
            }
          }
        },
        {
          "name": "POST Create Question (Author = john) ✅",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"What is the capital of France?\",\n  \"options\": [\"Berlin\", \"Madrid\", \"Paris\", \"Rome\"],\n  \"keywords\": [\"geography\", \"europe\"],\n  \"correctAnswerIndex\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/questions",
              "host": ["{{baseUrl}}"],
              "path": ["questions"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res._id) {",
                  "    pm.collectionVariables.set('questionId', res._id);",
                  "    console.log('questionId saved:', res._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST Create Question (No Token) ❌ 401",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Unauthorized question\",\n  \"options\": [\"A\", \"B\"],\n  \"correctAnswerIndex\": 0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/questions",
              "host": ["{{baseUrl}}"],
              "path": ["questions"]
            }
          }
        },
        {
          "name": "PUT Update Question (Author = john) ✅",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"What is the capital of France? (updated)\",\n  \"correctAnswerIndex\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/questions/{{questionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["questions", "{{questionId}}"]
            }
          }
        },
        {
          "name": "PUT Update Question (Admin tries to edit john's question) ❌ 403",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Admin trying to edit john's question\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/questions/{{questionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["questions", "{{questionId}}"]
            }
          }
        },
        {
          "name": "DELETE Question (Admin tries to delete john's question) ❌ 403",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/questions/{{questionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["questions", "{{questionId}}"]
            }
          }
        },
        {
          "name": "DELETE Question (Author = john) ✅",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/questions/{{questionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["questions", "{{questionId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Quizzes",
      "item": [
        {
          "name": "GET All Quizzes (Anyone) ✅",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/quizzes",
              "host": ["{{baseUrl}}"],
              "path": ["quizzes"]
            }
          }
        },
        {
          "name": "GET Single Quiz (Anyone) ✅",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/quizzes/{{quizId}}",
              "host": ["{{baseUrl}}"],
              "path": ["quizzes", "{{quizId}}"]
            }
          }
        },
        {
          "name": "POST Create Quiz (Admin) ✅",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"General Knowledge Quiz\",\n  \"description\": \"A simple quiz about general knowledge\",\n  \"questions\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/quizzes",
              "host": ["{{baseUrl}}"],
              "path": ["quizzes"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res._id) {",
                  "    pm.collectionVariables.set('quizId', res._id);",
                  "    console.log('quizId saved:', res._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST Create Quiz (Ordinary User) ❌ 403",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Unauthorized Quiz\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/quizzes",
              "host": ["{{baseUrl}}"],
              "path": ["quizzes"]
            }
          }
        },
        {
          "name": "POST Create Quiz (No Token) ❌ 401",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"No Token Quiz\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/quizzes",
              "host": ["{{baseUrl}}"],
              "path": ["quizzes"]
            }
          }
        },
        {
          "name": "PUT Update Quiz (Admin) ✅",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"General Knowledge Quiz (updated)\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/quizzes/{{quizId}}",
              "host": ["{{baseUrl}}"],
              "path": ["quizzes", "{{quizId}}"]
            }
          }
        },
        {
          "name": "PUT Update Quiz (Ordinary User) ❌ 403",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Ordinary user cannot update\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/quizzes/{{quizId}}",
              "host": ["{{baseUrl}}"],
              "path": ["quizzes", "{{quizId}}"]
            }
          }
        },
        {
          "name": "DELETE Quiz (Ordinary User) ❌ 403",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/quizzes/{{quizId}}",
              "host": ["{{baseUrl}}"],
              "path": ["quizzes", "{{quizId}}"]
            }
          }
        },
        {
          "name": "DELETE Quiz (Admin) ✅",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/quizzes/{{quizId}}",
              "host": ["{{baseUrl}}"],
              "path": ["quizzes", "{{quizId}}"]
            }
          }
        }
      ]
    }
  ]
}
